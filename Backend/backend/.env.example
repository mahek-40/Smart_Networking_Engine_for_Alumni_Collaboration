# ─── Environment Variable Template ────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env — only commit .env.example

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Local development:
MONGODB_URL=mongodb://localhost:27017

# MongoDB Atlas (production) — replace with your actual connection string:
# MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

DATABASE_NAME=alumni_network

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_secure_jwt_secret_here
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ── Application ────────────────────────────────────────────────────────────────
PROJECT_NAME="Smart Networking Engine for Alumni Collaboration"
APP_VERSION=1.0.0
APP_ENV=development         # development | staging | production

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Production example: ALLOWED_ORIGINS=https://yourapp.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
